# Copy this file to `.env.local` for local dev.
# On Vercel, set the same vars in Project Settings → Environment Variables.
#
# NEXT_PUBLIC_ prefix is required — plan IDs are rendered into the browser
# (data-whop-checkout-plan-id on the checkout div).

# Member Pass (1 / 3 / 6 / 9 / 12 months)
NEXT_PUBLIC_WHOP_PLAN_MEMBER_1M=plan_xxxxxxxxxxxxx
NEXT_PUBLIC_WHOP_PLAN_MEMBER_3M=plan_xxxxxxxxxxxxx
NEXT_PUBLIC_WHOP_PLAN_MEMBER_6M=plan_xxxxxxxxxxxxx
NEXT_PUBLIC_WHOP_PLAN_MEMBER_9M=plan_xxxxxxxxxxxxx
NEXT_PUBLIC_WHOP_PLAN_MEMBER_12M=plan_xxxxxxxxxxxxx

# Insider Pass (1 / 3 / 6 / 9 / 12 months)
NEXT_PUBLIC_WHOP_PLAN_INSIDER_1M=plan_xxxxxxxxxxxxx
NEXT_PUBLIC_WHOP_PLAN_INSIDER_3M=plan_xxxxxxxxxxxxx
NEXT_PUBLIC_WHOP_PLAN_INSIDER_6M=plan_xxxxxxxxxxxxx
NEXT_PUBLIC_WHOP_PLAN_INSIDER_9M=plan_xxxxxxxxxxxxx
NEXT_PUBLIC_WHOP_PLAN_INSIDER_12M=plan_xxxxxxxxxxxxx

# Tip (one-time $1)
NEXT_PUBLIC_WHOP_PLAN_TIP=plan_xxxxxxxxxxxxx
